# BackupMGR — ScriptGain product manifest (sourced by ../install.sh)
# Only KEY=VALUE lines; no logic.

PRODUCT_NAME="BackupMGR"
PHP_VER="8.3"
DB_NAME="backupmgr_db"
DB_USER="backupmgr"
APP_DIR="/var/www/backupmgr"

# Primary source: the product's PUBLIC git repo (source-available; the license,
# not code secrecy, is the gate — enforced by the compiled Go agent). Override
# REF=v1.0.0 to pin a tag. Set this to the real repo on the ScriptGain org.
REPO="https://github.com/scriptgain/backup-mgr.git"
REF="main"

# Fallback only (used when REPO is unset): a signed release tarball on the mirror.
# RELEASE_URL="https://install.scriptgain.com/releases/backup-manager-latest.tar.gz"

# Artisan command run once after migrate (seeds license statuses, brand, etc.).
BOOTSTRAP_CMD="backup:bootstrap"
