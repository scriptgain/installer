# StorageMGR — ScriptGain product manifest (sourced by ../install.sh)
PRODUCT_NAME="StorageMGR"
PHP_VER="8.3"
DB_NAME="storagemgr_db"
DB_USER="storagemgr"
APP_DIR="/var/www/storagemgr"
REPO="https://github.com/scriptgain/storage-mgr.git"
REF="main"
BOOTSTRAP_CMD=""
STORE_SLUG="storagemanager"
S3_ENDPOINT="1"          # StorageMGR ships an S3 API; install.sh sets up a dedicated endpoint when S3_DOMAIN is given
